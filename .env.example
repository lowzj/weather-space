# Weather Dashboard Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/weather_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=weather_db
DB_USER=weather_user
DB_PASSWORD=weather_password

# OpenWeatherMap API Configuration
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
OPENWEATHER_BASE_URL=http://api.openweathermap.org/data/2.5

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Application Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Weather Data Collection
FETCH_INTERVAL_MINUTES=15
DEFAULT_LOCATIONS=["New York,US", "London,GB", "Tokyo,JP", "Sydney,AU"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=weather_dashboard.log